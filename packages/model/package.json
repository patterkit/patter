{
  "name": "@patterkit/model",
  "version": "0.1.2",
  "description": "Patter data-model types: source (scene/block/group/snippet/beat/jump), project, locale, authoring. The shape source-of-truth.",
  "type": "module",
  "license": "MIT",
  "author": "Ian Thomas",
  "homepage": "https://patterkit.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/patterkit/patter.git",
    "directory": "packages/model"
  },
  "bugs": "https://github.com/patterkit/patter/issues",
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean"
  },
  "dependencies": {
    "@wildwinter/expr": "^0.3.0"
  }
}
