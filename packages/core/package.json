{
  "name": "@patterkit/core",
  "version": "0.1.2",
  "description": "Patter core: stable id generation, readable-handle computation, canonical (de)serialisation, and the structural validator.",
  "type": "module",
  "license": "MIT",
  "author": "Ian Thomas",
  "homepage": "https://patterkit.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/patterkit/patter.git",
    "directory": "packages/core"
  },
  "bugs": "https://github.com/patterkit/patter/issues",
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean"
  },
  "dependencies": {
    "@patterkit/model": "0.1.2",
    "json5": "^2.2.3"
  }
}
