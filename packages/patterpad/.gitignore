# Mac document icons baked from branding/document-icons/square/*.png by
# scripts/build-mac-icons.sh, a prerequisite of every `npm run dist:mac` -
# build artifacts, not source. The Windows .ico files are COMMITTED instead:
# scripts/build-win-icons.mjs resizes with sips, which only exists on macOS,
# so the windows CI runner can't regenerate them (regenerate on a Mac when
# the branding changes).
/build/doc-patter.icns
/build/doc-patterproj.icns
/build/doc-patterc.icns
